# ============================================================================
#  ghost.reviews — environment template.  COST = $0 (free tiers + sponsor credits).
#  Copy to .env.local and fill in.  Never commit real keys (.env.local is gitignored).
# ============================================================================

# ---- LLM provider (pick a FREE option — no credit card needed) ----
#   groq   -> https://console.groq.com/keys      (free, fast; default)
#   gemini -> https://aistudio.google.com/apikey (free tier)
#   runpod -> use the hackathon's free RunPod sponsor credits (also enters the RunPod challenge)
#   anthropic / openai -> OPTIONAL, PAID — leave blank to stay 100% free
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

GROQ_API_KEY=
GEMINI_API_KEY=
# Optional paid providers (NOT required — leave blank):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Nimble (live web crawl) — use the FREE hackathon sponsor credits ----
# Grab the participant key from the Devpost "Updates" tab / kickoff email / sponsor Discord.
NIMBLE_API_KEY=
NIMBLE_BASE_URL=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# true (or a query that matches a bundled fixture) => cached results, NO network, NO keys needed.
DEMO_MODE=false
