# ---- LLM (review analysis) ----
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Fast + cheap for batched review analysis. Swap to claude-sonnet-4-6 if quality needs it.
LLM_MODEL=claude-haiku-4-5-20251001

# ---- Nimble (live web crawl) ----
# Get a key from your Nimble account. Verify base URL + endpoints in the current Nimble docs.
NIMBLE_API_KEY=
NIMBLE_BASE_URL=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# When true (or when the query matches a bundled fixture), scans return cached results with no network.
DEMO_MODE=false
